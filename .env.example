# Copy to .env and adjust as needed. All values are optional; defaults shown.

# HTTP port the server listens on.
PORT=8080

# Path to the SQLite database file. Mappings persist here across restarts.
DB_PATH=shortlink.db

# Base URL used to build short links in responses.
# Defaults to http://localhost:$PORT when empty.
BASE_URL=

# Length of generated short codes (62^7 ≈ 3.5e12 possibilities at 7).
CODE_LENGTH=7

# Max attempts to generate a non-colliding code before failing.
MAX_RETRIES=5
